{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "..",
    "paths": {
      "meilisearch": [
        "data-migration/node_modules/meilisearch/dist/meilisearch.d.ts"
      ],
      "../server/*": [
        "server/*"
      ]
    }
  },
  "include": [
    "*.ts",
    "../server/src/models/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}